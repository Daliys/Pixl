--- !u!1001 &7684452190444263428
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 8269047233602901226}
    m_Modifications:
    - target: {fileID: 697857745664481778, guid: 24e1cc5d7557a49389e49c37aaeae455, type: 3}
