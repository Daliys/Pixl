    - target: {fileID: 697857745664481779, guid: 24e1cc5d7557a49389e49c37aaeae455, type: 3}
      propertyPath: m_text
      value: "\u044D\u0442\u043E \u0442\u043E\u0442 \u0432\u0438\u0434 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
        \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043A\u0430\u043A \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435
        \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u0438\u0445 \u043A\u0432\u0430\u0440\u0442\u0430\u043B\u043E\u0432
        \u2014 \u043E\u043D \u0438\u0437\u043C\u0435\u0440\u044F\u0435\u0442 \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u044E
        \u043D\u0435 \u043F\u043E \u043A\u0440\u0430\u0442\u0447\u0430\u0439\u0448\u0435\u0439
        \u043F\u0440\u044F\u043C\u043E\u0439, \u0430 \u043F\u043E \u0431\u043B\u043E\u043A\u0430\u043C,
        \u043F\u0440\u0438\u0447\u0451\u043C \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044F
        \u0437\u0434\u0435\u0441\u044C \u043D\u0435 \u0438\u043C\u0435\u0435\u0442
        \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F."
